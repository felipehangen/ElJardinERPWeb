{
  "name": "web",
  "private": true,
  "version": "1.0.1",
  "description": "El Jardin ERP Management System",
  "author": "Felipe <felipe@eljardin.cr>",
  "homepage": "./",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:pack": "node scripts/build-signed.cjs",
    "deploy": "gh-pages -d dist"
  },
  "build": {
    "appId": "com.eljardin.erp",
    "productName": "El Jardin ERP",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.business",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/icon2.png"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.2.1",
    "electron": "40.0.0",
    "electron-builder": "26.4.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "lucide-react": "^0.562.0",
    "postcss": "^8.5.6",
    "puppeteer": "^24.37.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "wait-on": "^9.0.3",
    "zustand": "^5.0.10"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0"
  }
}
